{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://symcio.tw/schemas/abvi/visibility_result.schema.json",
  "title": "VisibilityResult",
  "description": "Canonical ABVI single-measurement record.",
  "type": "object",
  "required": ["brand", "engine", "category", "query", "mentioned", "score", "timestamp"],
  "properties": {
    "brand": {
      "type": "string",
      "description": "Brand name under measurement."
    },
    "brand_domain": {
      "type": "string",
      "description": "Primary domain of the brand (optional; strips protocol and subdomain)."
    },
    "engine": {
      "type": "string",
      "enum": ["chatgpt", "claude", "gemini", "perplexity"],
      "description": "AI engine that generated the response."
    },
    "engine_model": {
      "type": "string",
      "description": "Specific model identifier (e.g., gpt-4o-mini-2024-07-18)."
    },
    "category": {
      "type": "string",
      "enum": ["top_companies", "alternatives", "problem", "comparison"],
      "description": "Prompt category."
    },
    "query": {
      "type": "string",
      "description": "Exact prompt string sent to the engine."
    },
    "response_excerpt": {
      "type": "string",
      "maxLength": 500,
      "description": "First 500 characters of the engine response."
    },
    "mentioned": {
      "type": "boolean",
      "description": "Whether the brand (or its primary domain) appears in the response."
    },
    "rank_position": {
      "type": ["integer", "null"],
      "minimum": 1,
      "maximum": 100,
      "description": "Position in list-style answers; null if not list-structured."
    },
    "sentiment": {
      "type": ["string", "null"],
      "enum": ["positive", "neutral", "negative", null],
      "description": "Sentiment of the mention; null if not mentioned."
    },
    "competitors": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 20,
      "description": "Competitor names extracted from the response."
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Per-measurement ABVI sub-score."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC ISO 8601 timestamp of the measurement."
    }
  },
  "additionalProperties": false
}
